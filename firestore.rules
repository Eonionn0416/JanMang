rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function myRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return myRole() == "admin";
    }

    function isDeveloper() {
      return myRole() == "developer" || myRole() == "admin";
    }

    function threadDoc(threadId) {
      return get(/databases/$(database)/documents/directThreads/$(threadId));
    }

    function threadExists(threadId) {
      return exists(/databases/$(database)/documents/directThreads/$(threadId));
    }

    function isThreadParticipantById(threadId) {
      return signedIn()
        && threadExists(threadId)
        && request.auth.uid in threadDoc(threadId).data.participantUids;
    }

    function isValidThreadCreate() {
      return signedIn()
        && request.resource.data.participantUids is list
        && request.resource.data.participantUids.size() == 2
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.participantKey is string;
    }

    function isValidThreadUpdate() {
      return signedIn()
        && request.auth.uid in resource.data.participantUids
        && request.resource.data.participantUids == resource.data.participantUids
        && request.resource.data.participantKey == resource.data.participantKey;
    }

    function isValidMessageCreate(threadId) {
      return signedIn()
        && isThreadParticipantById(threadId)
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.createdAt != null
        && (
          request.resource.data.type == "text" ||
          request.resource.data.type == "forward"
        );
    }

    function isPostOwner() {
      return signedIn() && (
        (resource.data.authorUid != null && resource.data.authorUid == request.auth.uid) ||
        (resource.data.createdBy != null && resource.data.createdBy == request.auth.uid)
      );
    }

    match /users/{uid} {
      allow get: if signedIn();
      allow list: if signedIn();
      allow create: if isOwner(uid);

      allow update: if (
        isOwner(uid) &&
        request.resource.data.role == resource.data.role
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn();

      allow update: if signedIn() && (
        isPostOwner() ||
        isAdmin()
      );

      allow delete: if signedIn() && (
        isPostOwner() ||
        isAdmin()
      );
    }

    match /posts/{postId}/updates/{updateId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.toUid == request.auth.uid;
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.toUid == request.auth.uid;
      allow delete: if signedIn() && resource.data.toUid == request.auth.uid;
    }

    match /directThreads/{threadId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participantUids;
      allow create: if isValidThreadCreate();
      allow update: if isValidThreadUpdate();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isThreadParticipantById(threadId);
        allow create: if isValidMessageCreate(threadId);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }
  }
}
